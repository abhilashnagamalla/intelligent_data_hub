{
  "extends": ["stylelint-config-recommended"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "layer",
          "tailwind",
          "apply",
          "responsive",
          "screen",
          "config"
        ]
      }
    ],
    "declaration-block-no-redundant-longhand-properties": null,
    "media-query-no-invalid": null,
    "function-no-unknown": null
  }
}
