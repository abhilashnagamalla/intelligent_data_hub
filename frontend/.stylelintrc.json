{
  "extends": "stylelint-config-recommended",
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "layer", 
          "apply",
          "responsive",
          "screen"
        ]
      }
    ],
    "declaration-block-no-redundant-longhand-properties": null
  }
}
